<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LibraryAppInteractive.LibraryBrowsePage"
             Title="Browse Interactive Library">
    <Grid RowDefinitions="auto,auto,auto,auto" ColumnDefinitions="*,*,*" RowSpacing="10" Margin="10">
        <Label Grid.Row="0" Grid.Column="0" Text="Search for book"/>
        <Entry x:Name="entSearch" Grid.Row="0" Grid.Column="1" Text="name or ISBN" Opacity="0.5"/>
        <Button x:Name="_btnSearch" Grid.Row="0" Grid.Column="2" Text="SEARCH"/>

        <Label Grid.Row="1" Grid.Column="0" Text="Borrowed on: "/>
        <DatePicker x:Name="_dpStart" Grid.Row="1" Grid.Column="1"/>

        <Label Grid.Row="2" Grid.Column="0" Text="Returned on: "/>
        <DatePicker x:Name="_dpEnd" Grid.Row="2" Grid.Column="1"/>
        <Border Grid.Row="3" Grid.Column="0"  Grid.ColumnSpan="3">
            <CollectionView x:Name="_lstBooks" />
        </Border>
    </Grid>
</ContentPage>
