<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LibraryAppInteractive.LibraryBrowsePage"
             Title="Browse Interactive Library">
    <Grid RowDefinitions="auto,auto,auto,auto" ColumnDefinitions="*,*,*" RowSpacing="10" Margin="10">
        <Label Grid.Row="0" Grid.Column="0" Text="Search for book"/>
        <HorizontalStackLayout Grid.Row="0" Grid.Column="1" >
            <Entry x:Name="_entName" Text="Book Name" Opacity="0.5"/>
            <Entry x:Name="_entISBN" Text="Book ISBN" Opacity="0.5"/>
        </HorizontalStackLayout>
        <Button x:Name="_btnSearch" Grid.Row="0" Grid.Column="2" Text="SEARCH" Clicked="OnSearchBook"/>

        <Label Grid.Row="1" Grid.Column="0" Text="Borrowed on: "/>
        <DatePicker x:Name="_dpStart" Grid.Row="1" Grid.Column="1"/>
        <Button x:Name="_btnBorrow" Grid.Row="1" Grid.Column="2" Text="BORROW" Clicked="OnBorrowBook"/>

        <Label Grid.Row="2" Grid.Column="0" Text="Returned on: "/>
        <DatePicker x:Name="_dpEnd" Grid.Row="2" Grid.Column="1"/>
        <Button x:Name="_btnReturn" Grid.Row="2" Grid.Column="2" Text="RETURN" Clicked="OnReturnBook"/>

        <Border Grid.Row="3" Grid.Column="0"  Grid.ColumnSpan="3">
            <CollectionView x:Name="_lstBooks" SelectionMode="Single"/>
        </Border>
    </Grid>
</ContentPage>
