<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LibraryAppInteractive.LibraryAdminPage"
             Title="Manage Book Assets">
    <Grid RowDefinitions="auto,auto,auto" ColumnDefinitions="*,*,*" RowSpacing="10" Margin="10">
        <Label Grid.Row="0" Grid.Column="0" Text="Book Registration"/>
        <VerticalStackLayout Grid.Row="0" Grid.Column="1" >
            <Entry x:Name="_entName" Text="Book Name" Opacity="0.5"/>
            <Entry x:Name="_entISBN" Text="Book ISBN" Opacity="0.5"/>
            <Entry x:Name="_entAuthor" Text="Book Author" Opacity="0.5"/>
            <Entry x:Name="_entCopies" Text="Number of copies." Opacity="0.5"/>
            <Picker x:Name="_pckType" Title="{OnPlatform MacCatalyst='', Default='Select book type'}">
                <Picker.Items>
                    <x:String>Paper</x:String>
                    <x:String>Digital</x:String>
                    <x:String>Audio</x:String>
                </Picker.Items>
            </Picker>
        </VerticalStackLayout>
        
        <Button x:Name="_btnRegister" Grid.Row="0" Grid.Column="2" Text="REGISTER" Clicked="OnRegisterBook"/>

        <Label Grid.Row="1" Grid.Column="0" Text="Book Availability"/>
        <HorizontalStackLayout Grid.Row="1" Grid.Column="1">
            <Entry x:Name="_entSearchName"  Text="Name" Opacity="0.5"/>
            <Entry x:Name="_entSearchISBN" Text="ISBN" Opacity="0.5"/>
        </HorizontalStackLayout>
        <Button x:Name="_btnSearch" Grid.Row="1" Grid.Column="2" Text="SEARCH" FontSize="10" Clicked="OnSearch"/>
        
        <Border Grid.Row="2" Grid.Column="0">
            <CollectionView x:Name="_lstBooks" SelectionMode="Single" SelectionChanged="OnSelectedBook">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <VerticalStackLayout Padding="8">
                            <Label Text="{Binding Name}" FontAttributes="Bold" />
                            <Label Text="{Binding ISBN}" FontSize="12" />
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Border>

        <Border Grid.Row="2" Grid.Column="1">
            <CollectionView x:Name="_lstAssets">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <VerticalStackLayout Padding="8">
                            <Label Text="{Binding LibraryID}" FontAttributes="Bold" />
                            <Label Text="{Binding Status}" FontSize="12" />
                            <Label Text="{Binding IsAvailable}" FontSize="12" />
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Border>
    </Grid>
</ContentPage>